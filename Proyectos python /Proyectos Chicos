def inicializar_db():
    conn = sqlite3.connect('ofertas.db')
    cursor = conn.cursor()
    cursor.execute('CREATE TABLE IF NOT EXISTS enviadas (link TEXT PRIMARY KEY)')
    conn.commit()
    conn.close()
inicializar_db()


async def enviar_aviso(titulo_empleo, link_empleo):
    bot = Bot(token=TOKEN)

    await bot.send_message(chat_id=MI_ID, text=f"✅ ¡Oferta encontrada!\n\nTrabajo: {titulo_empleo}\nLink: {link_empleo}")

async def buscar_buscojobs():
    async with httpx.AsyncClient() as client:
        
        respuesta = await client.get("https://www.buscojobs.com.uy/ofertas", timeout=40.0)
        
        print(respuesta.status_code)
        
        soup = BeautifulSoup(respuesta.text, 'html.parser')
        
        print(soup.title.text)
        
        ofertas = soup.find_all('a', href=True)
        
        print(f"Encontré {len(ofertas)} links de ofertas para revisar.")
        
        for oferta in ofertas:
        
            titulo = oferta.text.strip().lower()
        
            if not titulo: 
       
                continue
       
            enlace_corto = oferta['href']
       
            link_final = f"https://www.buscojobs.com.uy{enlace_corto}"

            if any(palabra in titulo for palabra in PALABRAS_CLAVE):
                conn = sqlite3.connect('ofertas.db')
                cursor = conn.cursor()

                cursor.execute('SELECT link FROM enviadas WHERE link = ?', (link_final,))
                resultado = cursor.fetchone()

                if resultado is None:
                    print(f"✅ ¡NUEVA OFERTA!: {titulo}")
                    await enviar_aviso(titulo, link_final)

                    cursor.execute('INSERT INTO enviadas (link) VALUES (?)', (link_final,))
                    conn.commit()

                else: 
                    print(f"⏭️ Omitiendo repetida: {titulo}")

                conn.close()

        print("✅ Escaneo finalizado. No hay más ofertas por ahora.")

