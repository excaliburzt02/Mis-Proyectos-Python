                else: 
                    print(f"⏭️ Omitiendo repetida: {titulo}")

                conn.close()

        print("✅ Escaneo finalizado. No hay más ofertas por ahora.")

async def buscar_computrabajo():
    url = "https://uy.computrabajo.com/ofertas-de-trabajo/?q=mecanico"
    async with httpx.AsyncClient(headers=HEADERS, follow_redirects=True) as client:
        try:
            respuesta = await client.get(url, timeout=40.0)
            
            if respuesta.status_code == 200:
                soup = BeautifulSoup(respuesta.text, 'html.parser')
                ofertas = soup.find_all('article', class_='box_offer')
                
                print(f"🔎 CompuTrabajo: Analizando {len(ofertas)} ofertas...")

                for oferta in ofertas:
                    enlace_tag = oferta.find('a', class_='js-o-link')
                    if not enlace_tag:
                        continue

                    info_tag = oferta.find('p', class_='fs16')
                    ubicacion = info_tag.text.lower() if info_tag else ""

                    link_final = "https://uy.computrabajo.com" + enlace_tag['href']
                    titulo = enlace_tag.text.strip().lower()
            

                    if any(palabra in titulo for palabra in PALABRAS_CLAVE) and "montevideo" in ubicacion:
                        conn = sqlite3.connect('ofertas.db')
                        cursor = conn.cursor()
                        cursor.execute('SELECT link FROM enviadas WHERE link = ?', (link_final,))
                       
                        if cursor.fetchone() is None:
                            print(f"✅ ¡NUEVA OFERTA (CompuTrabajo)!: {titulo}")
                            await enviar_aviso(titulo, link_final)
                            cursor.execute('INSERT INTO enviadas (link) VALUES (?)', (link_final,))
                            conn.commit()
                        conn.close()

            else:
                print(f"❌ CompuTrabajo respondió con error: {respuesta.status_code}")


        except Exception as e:
            print(f"⚠️ Hubo un problema de conexión con CompuTrabajo: {e}")
            print("🔄 Se reintentará en la próxima ronda.")
              

